{
  "name": "jonplummer-11ty",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node scripts/test-runner.js",
    "test:spell": "node scripts/test-runner.js spell",
    "test:spell:file": "node scripts/test/spell.js",
    "test:spell:changed": "node scripts/test/spell.js --changed",
    "test:changed": "node scripts/test-changed.js",
    "build": "eleventy --quiet",
    "build:verbose": "eleventy",
    "dev": "eleventy --serve --watch --quiet",
    "dev:verbose": "eleventy --serve --watch",
    "clean": "rm -rf _site",
    "validate": "node scripts/test-runner.js html",
    "deploy": "node scripts/deploy/deploy.js",
    "changelog": "node scripts/content/generate-changelog.js",
    "convert-pdf": "node scripts/content/convert-pdf-pages.js",
    "convert-pdf-with-notes": "node scripts/content/convert-pdf-pages-with-notes.js",
    "generate-og-images": "node scripts/content/generate-og-images.js",
    "import-links": "node scripts/content/import-noteplan-links.js",
    "security-audit": "node scripts/security/security-audit.js",
    "color-gallery": "node scripts/color-explore/generate-gallery.js",
    "font-gallery": "node scripts/font-explore/generate-font-gallery.js",
    "lint:css": "stylelint \"src/**/*.css\""
  },
  "keywords": [],
  "author": "Jon Plummer",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@xmldom/xmldom": "^0.8.11",
    "apca-w3": "^0.1.9",
    "axe-core": "^4.11.1",
    "cheerio": "^1.2.0",
    "cspell": "^9.7.0",
    "culori": "^4.0.2",
    "html-validate": "^10.11.2",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "markdownlint-cli2": "^0.20.0",
    "nunjucks": "^3.2.4",
    "puppeteer": "^24.40.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "markdown-it": "^14.1.1"
  },
  "pnpm": {
    "overrides": {
      "markdown-it": ">=14.1.1"
    }
  }
}
