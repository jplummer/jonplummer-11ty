{#-
  Inline first-paint shell: blocks default blue/purple links and wrong page chrome
  before jonplummer.css loads. Keep in sync with :root body colors in that file.
-#}
<style>
  :root { color-scheme: light dark; }
  body {
    margin: 0;
    background-color: light-dark(oklch(96.4% 0.0058 264.53deg), oklch(10% 0.0058 264.53deg));
    color: light-dark(oklch(29.6% 0.01 260.71deg), oklch(93% 0.01 260.71deg));
    font-family: "Public Sans", sans-serif;
  }
  a:any-link { color: inherit; }
  hgroup h1, article h1, main > h1 {
    font-family: "Big Shoulders", sans-serif;
  }
</style>
